# Unity standard gitignore

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Build]/
/[Builds]/
/[Logs]/
/[MemoryCaptures]/
/[UserSettings]/

# Asset meta files for folders that are ignored
/[Ll]ibrary.meta
/[Tt]emp.meta
/[Oo]bj.meta
/[Build].meta
/[Builds].meta
/[Logs].meta
/[UserSettings].meta

# Autogenerated VS/VS Code project files
/*.csproj
/*.unityproj
/*.sln
/*.suo
/*.tmp
/*.user
/*.userprefs
/*.pidb
/*.booproj
/*.svd
/*.pdb
/*.opendb
/*.db

# Unity3D Generated Meta Files
/*.pidb.meta
/*.pdb.meta

# Unity3D Generated File Types
/*.log

# Crashlytics generated file
crashlytics-build.properties

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
